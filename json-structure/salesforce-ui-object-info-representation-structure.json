{
  "type": "object",
  "description": "Metadata about a Salesforce object",
  "name": "ObjectInfoRepresentation",
  "properties": {
    "apiName": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "labelPlural": {
      "type": "string"
    },
    "keyPrefix": {
      "type": "string"
    },
    "createable": {
      "type": "boolean"
    },
    "updateable": {
      "type": "boolean"
    },
    "deleteable": {
      "type": "boolean"
    },
    "queryable": {
      "type": "boolean"
    },
    "fields": {
      "type": "object",
      "description": "Field metadata indexed by field API name"
    },
    "recordTypeInfos": {
      "type": "object"
    },
    "themeInfo": {
      "type": "object",
      "properties": {
        "color": {
          "type": "string"
        },
        "iconUrl": {
          "type": "string"
        }
      }
    }
  },
  "$schema": "https://json-structure.org/draft/2020-12/schema"
}