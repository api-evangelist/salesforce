{
  "type": "object",
  "description": "Collection of list views for an object",
  "name": "ListViewCollection",
  "properties": {
    "count": {
      "type": "integer"
    },
    "currentPageToken": {
      "type": "string"
    },
    "nextPageToken": {
      "type": "string"
    },
    "previousPageToken": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Summary information about a list view",
        "properties": {
          "id": {
            "type": "string"
          },
          "apiName": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    }
  },
  "$schema": "https://json-structure.org/draft/2020-12/schema"
}