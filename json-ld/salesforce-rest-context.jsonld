{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "ApiVersion": {
      "@id": "ns:ApiVersion",
      "@context": {
        "version": {
          "@id": "ns:version",
          "@type": "xsd:string"
        },
        "label": {
          "@id": "ns:label",
          "@type": "xsd:string"
        },
        "url": {
          "@id": "ns:url",
          "@type": "xsd:string"
        }
      }
    },
    "SObjectRecord": {
      "@id": "ns:SObjectRecord",
      "@context": {
        "attributes": "ns:attributes",
        "Id": {
          "@id": "ns:Id",
          "@type": "xsd:string"
        }
      }
    },
    "SObjectDescribe": {
      "@id": "ns:SObjectDescribe",
      "@context": {
        "name": {
          "@id": "ns:name",
          "@type": "xsd:string"
        },
        "label": {
          "@id": "ns:label",
          "@type": "xsd:string"
        },
        "labelPlural": {
          "@id": "ns:labelPlural",
          "@type": "xsd:string"
        },
        "keyPrefix": {
          "@id": "ns:keyPrefix",
          "@type": "xsd:string"
        },
        "queryable": {
          "@id": "ns:queryable",
          "@type": "xsd:boolean"
        },
        "searchable": {
          "@id": "ns:searchable",
          "@type": "xsd:boolean"
        },
        "createable": {
          "@id": "ns:createable",
          "@type": "xsd:boolean"
        },
        "updateable": {
          "@id": "ns:updateable",
          "@type": "xsd:boolean"
        },
        "deletable": {
          "@id": "ns:deletable",
          "@type": "xsd:boolean"
        },
        "fields": "ns:fields",
        "urls": "ns:urls"
      }
    },
    "QueryResult": {
      "@id": "ns:QueryResult",
      "@context": {
        "totalSize": {
          "@id": "ns:totalSize",
          "@type": "xsd:integer"
        },
        "done": {
          "@id": "ns:done",
          "@type": "xsd:boolean"
        },
        "nextRecordsUrl": {
          "@id": "ns:nextRecordsUrl",
          "@type": "xsd:string"
        },
        "records": "ns:records"
      }
    },
    "SearchResult": {
      "@id": "ns:SearchResult",
      "@context": {
        "searchRecords": "ns:searchRecords"
      }
    },
    "CompositeRequest": {
      "@id": "ns:CompositeRequest",
      "@context": {
        "allOrNone": {
          "@id": "ns:allOrNone",
          "@type": "xsd:boolean"
        },
        "collateSubrequests": {
          "@id": "ns:collateSubrequests",
          "@type": "xsd:boolean"
        },
        "compositeRequest": "ns:compositeRequest"
      }
    },
    "CompositeResponse": {
      "@id": "ns:CompositeResponse",
      "@context": {
        "compositeResponse": "ns:compositeResponse"
      }
    },
    "Error": {
      "@id": "ns:Error",
      "@context": {
        "message": {
          "@id": "ns:message",
          "@type": "xsd:string"
        },
        "errorCode": {
          "@id": "ns:errorCode",
          "@type": "xsd:string"
        },
        "fields": "ns:fields"
      }
    }
  }
}