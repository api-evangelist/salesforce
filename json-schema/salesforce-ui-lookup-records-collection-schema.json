{
  "type": "object",
  "description": "Collection of records matching a lookup search",
  "properties": {
    "count": {
      "type": "integer",
      "example": 42
    },
    "lookupResults": {
      "type": "array",
      "example": [],
      "items": {
        "type": "object",
        "properties": {
          "displayValue": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LookupRecordsCollection"
}