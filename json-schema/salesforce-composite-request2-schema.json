{
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "example": "example_value"
    },
    "url": {
      "type": "string",
      "example": "https://www.example.com"
    },
    "referenceId": {
      "type": "string",
      "example": "500123"
    },
    "body": {
